{
  "name": "basicbots",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --type-aware --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "pnpm typecheck && pnpm lint && pnpm format:check && pnpm test",
    "setup:browser": "playwright-core install chromium"
  },
  "dependencies": {
    "cheerio": "^1.2.0",
    "pino": "^10.3.1",
    "rebrowser-playwright": "^1.52.0",
    "rebrowser-playwright-core": "^1.52.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.61.0",
    "@types/node": "^24.10.1",
    "oxfmt": "0.45.0",
    "oxlint": "^1.60.0",
    "oxlint-tsgolint": "0.21.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
